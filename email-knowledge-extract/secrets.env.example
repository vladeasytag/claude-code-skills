# Copy to a private location (e.g. ~/.config/myproject/secrets.env), fill in, chmod 600.
# Point the pipeline at it with EKB_SECRETS_FILE, OR just export EKB_LLM_API_KEY directly.
# NEVER commit the real file.

# --- Required: primary LLM (any OpenAI-compatible /chat/completions endpoint) ---
EKB_LLM_API_KEY=sk-your-key-here
EKB_LLM_URL=https://your-endpoint.example/v1/chat/completions
EKB_MODEL=your-model-id
# EKB_SUM_MODEL=your-large-context-model-id   # optional; defaults to EKB_MODEL for summaries
# EKB_PROVIDER=ProviderA,ProviderB            # optional router-style provider pin

# --- Your organisation ---
EKB_OWN_DOMAIN=example.com
EKB_BUSINESS_DESC=a company that sells products and related supplies
# EKB_DATA_DIR=/absolute/path/for/outputs     # defaults to ../data next to src/

# --- Optional: fallback CLI LLM (used only if the primary is down; "" disables) ---
# EKB_FALLBACK_CMD=/usr/local/bin/your-llm-cli
# EKB_FALLBACK_MODEL=your-fallback-model

# --- Optional: ops alerting when the primary fails (Telegram-style bot; "" disables) ---
# EKB_ALERT_BOT_TOKEN_FILE=/path/to/bot_token
# EKB_ALERT_CHAT_ID=123456789

# --- Optional: external attachment doc pipeline ("<cmd> ingest <file>"; "" disables) ---
# EKB_DOCPIPE=/path/to/docpipe
