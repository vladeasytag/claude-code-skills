# Reply Auto-Drafting — configuration template.
# Copy to autodraft.env, fill in real values, and `source` it (or export these)
# before running run.sh / autodraft.py. NEVER commit the filled-in copy.

# --- Identities -------------------------------------------------------------
# The Gmail auth profile name your auth.py understands (see README).
AUTODRAFT_ACCOUNT=owner
# The mailbox you draft for (the "owner").
AUTODRAFT_OWNER_EMAIL=owner@example.com
# A teammate always added to CC on every draft (e.g. a colleague who follows up).
AUTODRAFT_CC_EMAIL=teammate@example.com
# Mail from this domain (or the owner/teammate) is treated as internal and never drafted.
AUTODRAFT_INTERNAL_DOMAIN=example.com

# --- Knowledge base / attachment -------------------------------------------
# Project root that holds knowledge-base/ (products, writing-styles, from-emails).
# Defaults to two directories above autodraft.py if unset.
#AUTODRAFT_PROJECT_ROOT=/home/you/myproject
# Directory containing your auth.py (get_credentials). Defaults to PROJECT_ROOT.
#AUTODRAFT_AUTH_DIR=/home/you/myproject/email
# Directory containing an optional kb_index module (semantic retrieval).
#AUTODRAFT_KB_INDEX_DIR=/home/you/myproject/kb
# File attached on the FIRST reply in a thread (price list, brochure, ...).
# Leave unset to attach nothing.
#AUTODRAFT_ATTACHMENT=/home/you/myproject/knowledge-base/products/price-list.pdf

# --- Main (cloud) LLM -------------------------------------------------------
# Path to the interactive LLM CLI used for quality drafting/learning.
CLAUDE_BIN=claude
AUTODRAFT_MODEL=opus

# --- Behaviour knobs --------------------------------------------------------
AUTODRAFT_MAX_DRAFTS=5             # cap per run so it can't flood Drafts
AUTODRAFT_SCAN_WINDOW=newer_than:4d

# --- Privacy layer (optional) ----------------------------------------------
# 1 = mask PII before any text reaches the cloud LLM; fall back to a local model
# when NER is down or hard PII survives masking. 0 = raw text to the cloud LLM.
AUTODRAFT_PRIVACY=1
# OpenAI-compatible endpoint for the local/private model (NER + fallback drafting).
AUTODRAFT_LOCAL_ENDPOINT=http://localhost:8000/v1/chat/completions
AUTODRAFT_LOCAL_MODEL=your-local-model
# API key for the above endpoint, if it needs one. Leave unset for a keyless local server.
#AUTODRAFT_LOCAL_API_KEY=

# --- Optional chat notification (Telegram Bot API shown) -------------------
# File holding a bot token, and file/id for the destination chat. Omit to disable pings.
#AUTODRAFT_TG_TOKEN_FILE=/home/you/myproject/telegram/bot_token
#AUTODRAFT_TG_CHAT_FILE=/home/you/myproject/telegram/notify_chat
#AUTODRAFT_TG_CHAT=123456789

# Optional: SQLite contacts DB (table `contacts(email, name, company, ...)`).
# When set, the drafter looks up senders whose emails carry no name (no
# signature) and greets them by first name from the CRM.
#DST_CRM_DB=/path/to/crm/contacts.db
