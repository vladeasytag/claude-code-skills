# Copy to the path referenced by $KB_SECRETS_FILE (default: ~/.config/myproject/secrets.env)
# and fill in your own key. NEVER commit the real file.
#
# Only kb_answer.py needs a key (for the tier-1 grounded LLM call). Plain `kb search`,
# `kb index`, `kb ask`, and `kb stats` need no key — only the embeddings endpoint.
#
# The key name here must match $KB_LLM_KEY_NAME (default: OPENROUTER_API_KEY).
# Alternatively, skip this file entirely and export KB_LLM_KEY in the environment.
OPENROUTER_API_KEY=sk-your-key-here
