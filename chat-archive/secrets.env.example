# Copy to ~/.config/chat-archive/secrets.env (or point SECRETS_ENV at this file),
# or just export OPENROUTER_API_KEY in the environment instead.
#
# API key for the "worker" classifier endpoint (OpenRouter by default). Only needed if
# you use the default OpenRouter-hosted worker model; not needed if you swap OR_URL to a
# local/keyless embedding-compatible endpoint.
OPENROUTER_API_KEY=sk-your-key-here
