# Copy to .env (or export in your cron/shell) and edit. All are optional; defaults shown.

# Which mailbox account keys to scan (must match keys in your gmail layer's config.ACCOUNTS).
FOLLOWUP_MAILBOXES=primary,secondary

# Your own domain — mail from this domain is treated as "us", never a pending customer.
OWN_DOMAIN=example.com

# Digest delivery: where it goes, the From address, and which account key sends it.
FOLLOWUP_NOTIFY_TO=owner@example.com
FOLLOWUP_NOTIFY_FROM=agent@example.com
FOLLOWUP_NOTIFY_ACCOUNT=primary

# LLM triage backend (OpenAI-compatible /chat/completions). Bring your own endpoint.
LLM_URL=http://127.0.0.1:8080/v1/chat/completions
LLM_MODEL=local-model
LLM_API_KEY=
