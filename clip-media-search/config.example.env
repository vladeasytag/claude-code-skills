# CLIP media-search configuration (copy to config.env and source it, or export).
# All values are optional; defaults derive from the script location.

# Where indexed images are copied to (the media/KB folder).
# MEDIA_DIR=~/myproject/media

# Where the vector index + metadata are stored.
# CLIP_STORE_DIR=~/myproject/store

# Warm-server port.
# CLIP_SERVER_PORT=8477

# --- Swappable CLIP backend (any fastembed image/text pair in one vector space) ---
# CLIP_IMG_MODEL=Qdrant/clip-ViT-B-32-vision
# CLIP_TXT_MODEL=Qdrant/clip-ViT-B-32-text
# CLIP_DIM=512

# --- Optional: external doc-RAG pipeline for PDFs (a separate tool) ---
# If unset, PDFs handed to `./media add` are skipped. Set to an executable that
# accepts:  <docpipe> ingest <file.pdf>
# DOCPIPE=~/myproject/docpipe

# --- Optional: chat backend for show_media.py (send images into a chat) ---
# Directory containing a `tg_api` module (Telegram Bot API client or equivalent).
# CHAT_BACKEND_PATH=~/myproject/telegram
# Default destination chat id.
# CHAT_ID=123456789
