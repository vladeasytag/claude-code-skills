# docpipe configuration — copy to `config.env` and `source` it (or export these
# in your shell) before running docpipe. All values are OPTIONAL; the defaults in
# src/pipeline/config.py assume two local llama.cpp servers on localhost.
#
# Bring your own model endpoints — any OpenAI-compatible server works.

# --- Model endpoints (OpenAI-compatible /v1 base URLs) ---
export DOCPIPE_CHAT_URL="http://127.0.0.1:18182/v1"   # chat / instruct model
export DOCPIPE_EMB_URL="http://127.0.0.1:18183/v1"    # embedding model

# --- Model names (as your server advertises them / the --alias you set) ---
export DOCPIPE_CHAT_MODEL="local-chat"
export DOCPIPE_EMB_MODEL="local-embed"

# --- Embedding geometry (MUST match your embedding model) ---
export DOCPIPE_EMB_DIM="768"          # e.g. 768 for nomic-embed-text-v1.5
export DOCPIPE_EMB_TASK_PREFIX="1"    # "1" for nomic-style task prefixes, "0" to disable

# --- Where Markdown docs (structured queries + PDF conversions) live ---
# Defaults to <skill>/src/knowledge-base
# export DOCPIPE_KB_DIR="/path/to/your/knowledge-base"

# --- For src/start_servers.sh (llama.cpp example launcher) ---
# export LLAMA_BIN_DIR="$HOME/llama.cpp/build/bin"
# export CHAT_MODEL_GGUF="/path/to/your-7b-instruct.gguf"
# export EMB_MODEL_GGUF="/path/to/your-embed-model.gguf"
